# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
.pytest_cache/
.mypy_cache/

# HexGraph runtime data (never commit projects/artifacts/keys)
.hexgraph/
# per-worktree HEXGRAPH_HOME used during dev (DB, settings.json, projects).
# NB: gitignore has no trailing-comment support, so this comment is on its own line —
# `.hghome*/  # ...` would make the comment PART of the pattern and silently not match.
.hghome*/
*.db
*.sqlite3

# OS
.DS_Store
*.bak

# Frontend build artifacts (run `just ui` to build the SPA)
frontend/node_modules/
frontend/dist/
frontend/tsconfig.tsbuildinfo
src/hexgraph/web/dist/
# Build-time-stamped identity (scripts/bake_build_info.py); a generated artifact, never committed.
src/hexgraph/_build_info.py
.claude/
# …but DO track committed project skills (CLAUDE.md: capture workflows as skills under .claude/skills/),
# the merge-gate reviewer agent, and the checked-in hooks + their settings (NOT settings.local.json).
!.claude/
.claude/*
!.claude/skills/
!.claude/agents/
!.claude/hooks/
!.claude/settings.json
